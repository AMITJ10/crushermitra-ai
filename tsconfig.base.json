{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@crushermitra/auth": ["./packages/auth/src/index.ts"],
      "@crushermitra/config": ["./packages/config/src/index.ts"],
      "@crushermitra/database": ["./packages/database/src/index.ts"],
      "@crushermitra/domain": ["./packages/domain/src/index.ts"],
      "@crushermitra/i18n": ["./packages/i18n/src/index.ts"],
      "@crushermitra/integrations": ["./packages/integrations/src/index.ts"],
      "@crushermitra/permissions": ["./packages/permissions/src/index.ts"],
      "@crushermitra/reporting": ["./packages/reporting/src/index.ts"],
      "@crushermitra/ui": ["./packages/ui/src/index.ts"],
      "@crushermitra/validation": ["./packages/validation/src/index.ts"]
    }
  }
}

