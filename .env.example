DEFAULT_TIME_ZONE="Asia/Kolkata"
DEFAULT_LOCALE="en"

# Auth
AUTH_SECRET="replace-with-strong-random-secret"
ADMIN_AUTH_SECRET="replace-with-strong-random-admin-secret"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
AUTH_URL="http://localhost:3000"
PASSWORD_PEPPER="replace-with-secret-pepper"
PLATFORM_ADMIN_EMAIL="amitjadhav7383@gmail.com"
PLATFORM_ADMIN_NAME="Amit Jadhav"
PLATFORM_ADMIN_PASSWORD=""

# Database
DATABASE_URL="postgresql://crushermitra:crushermitra@localhost:5432/crushermitra"
POSTGRES_USER="crushermitra"
POSTGRES_PASSWORD="crushermitra"
POSTGRES_DB="crushermitra"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Object storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="ap-south-1"
S3_BUCKET="crushermitra-local"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# AI service
AI_SERVICE_URL="http://localhost:8000"
AI_TOOL_CALL_LOGGING_ENABLED="true"

# Integrations
